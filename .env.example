# PostgreSQL connection string used by the server and Drizzle.
# Matches the credentials in docker-compose.yml for local development.
DATABASE_URL=postgres://spartan:spartan@localhost:5432/spartan_db

# Secret used to encrypt the session cookie (iron-session).
# Must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

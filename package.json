{
  "name": "spartantournaments",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.1"
  },
  "scripts": {
    "ng": "ng",
    "dev": "vite",
    "start": "pnpm run dev",
    "build": "vite build",
    "watch": "vite build --watch",
    "test": "vitest",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.include='libs/calc-tournament/src/**' --coverage.include='src/server/**' --coverage.reporter=text --coverage.reporter=html",
    "preview": "node dist/analog/server/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "private": true,
  "dependencies": {
    "@analogjs/content": "^2.5.0",
    "@analogjs/router": "^2.5.0",
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ng-icons/core": ">=32.0.0 <34.0.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@spartan-ng/brain": "0.0.1-alpha.690",
    "@spartan-ng/ui-core": "0.0.1-alpha.380",
    "@tailwindcss/vite": "^4.1.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-angular": "^20.0.0",
    "front-matter": "^4.0.2",
    "iron-session": "^8.0.4",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "postcss": "^8.5.3",
    "postgres": "^3.4.9",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.4",
    "tslib": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.5.0",
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@analogjs/vitest-angular": "^2.5.0",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@spartan-ng/cli": "0.0.1-alpha.690",
    "@types/bcryptjs": "^3.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "^22.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "h3": "1.15.11",
    "jsdom": "^22.0.0",
    "prettier": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": "$vite",
    "vitest": "$vitest"
  }
}
